#include "torabo_tsuki_lp.dtsi"
#include <input/processors.dtsi>
#include <input/processors/temp_layer.dtsi>
#include <dt-bindings/zmk/input_transform.h>

&pointing_listener {
    input-processors = <
        &zip_xy_transform (INPUT_TRANSFORM_X_INVERT | INPUT_TRANSFORM_Y_INVERT)
        &zip_temp_layer 1 300
    >;

    scroll {
        layers = <4>;
        input-processors = <&zip_xy_transform INPUT_TRANSFORM_X_INVERT &zip_xy_to_scroll_mapper &zip_scroll_scaler 1 16>;
    };
};
